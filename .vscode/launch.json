{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DEBUG",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/src/dnfui",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "DEBUG COREDUMP",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/src/dnfui",
      "coreDumpPath": "${workspaceFolder}/core",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "DEBUG DOCKER",
      "type": "cppdbg",
      "request": "launch",
      "program": "/tmp/dnfui-build/debug/src/dnfui",
      "args": [],
      "stopAtEntry": false,
      "cwd": "/workspace",
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerServerAddress": "localhost:2345",
      "pipeTransport": {
        "pipeProgram": "docker",
        "pipeArgs": [
          "exec",
          "-i",
          "dnfui-gdb",
          "sh",
          "-c"
        ],
        "pipeCwd": "${workspaceFolder}",
        "debuggerPath": "/usr/bin/gdb"
      },
      "sourceFileMap": {
        "/workspace": "${workspaceFolder}"
      },
      "preLaunchTask": "DOCKER GDB SERVER",
      "postDebugTask": "DOCKER GDB STOP",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
